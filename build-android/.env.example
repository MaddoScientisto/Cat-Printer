# Copy this file to build-android/.env and adjust values for your machine.

# Android 15 target API keeps the APK suitable for current Android systems.
ANDROID_API=35
BUILD_TOOLS_VERSION=35.0.0
NDK_VERSION=27.2.12479018
NDK_API=23
COMMANDLINE_TOOLS_VERSION=11076708

# Use arm64 for current devices and armeabi-v7a for older, still common devices.
P4A_ARCHS=arm64-v8a,armeabi-v7a
P4A_PACKAGE=io.github.naitlee.catprinter
P4A_NAME=Cat Printer
P4A_PERMISSIONS=INTERNET,BLUETOOTH,BLUETOOTH_ADMIN,ACCESS_FINE_LOCATION,BLUETOOTH_SCAN,BLUETOOTH_CONNECT

# debug or release; the launcher argument overrides this value.
BUILD_MODE=debug

# Set to 1 to run p4a clean_builds and clean_dists before building.
CLEAN_BUILD=0

# Extra python-for-android arguments, split by shell-style whitespace.
P4A_EXTRA_ARGS=

# Optional release signing. Keep the real keystore in build-android/keys/ or another mounted path.
# RELEASE_KEYSTORE=/workspace/build-android/keys/mykeyfile.key
# RELEASE_SIGNKEY=mykey
# RELEASE_KEYSTORE_PASSWORD=
# RELEASE_SIGNKEY_PASSWORD=
